<?xml version="1.0" encoding="UTF-8"?>
<!--
  CRITICAL for stdio MCP transport: stdout is reserved strictly for MCP JSON-RPC.
  All logs MUST go to stderr. Never add a stdout/System.out appender here.
-->
<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
