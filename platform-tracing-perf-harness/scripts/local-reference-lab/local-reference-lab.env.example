# Copy to local-reference-lab.env and adjust (do not commit secrets).
# PR-9H-E2L — Gentoo local reference lab

LAB_PROFILE_ID=gentoo-local-reference-lab-v1
LAB_NAMESPACE=platform-tracing-reference-lab
LAB_KUBECTX=kind-platform-tracing-reference-lab
LAB_TIER=LOCAL_REFERENCE_LAB

# Gentoo host (SSH for setup; Docker remote for inventory from Windows)
LAB_HOST=192.168.100.70
LAB_SSH_USER=root
LAB_DOCKER_HOST=tcp://192.168.100.70:2375
LAB_KUBECTL=kubectl
# Gentoo kind lab: LAB_KUBECTL=/usr/local/bin/kubectl-v136

# Prometheus (optional — after approval-gated install)
# LAB_PROM_URL=http://127.0.0.1:9090

# JFR external path on Gentoo
# LAB_JFR_FILE=/tmp/jfr/local-reference.jfr

# kind cluster name
LAB_KIND_CLUSTER=platform-tracing-reference-lab

# Resource placeholders (local lab — not SRE-approved)
LAB_APP_CPU_LIMIT=2
LAB_APP_MEM_LIMIT=2Gi
LAB_COLLECTOR_CPU_LIMIT=500m
LAB_COLLECTOR_MEM_LIMIT=512Mi

# Load (pin after S0 calibration — do not treat as official TARGET_RPS)
LAB_TARGET_RPS=

# JFR / artifacts on Gentoo (outside git)
LAB_ARTIFACT_DIR=/var/tmp/platform-tracing-reference-lab-artifacts
LAB_ARTIFACT_DIR_FALLBACK=~/platform-tracing-reference-lab-artifacts

# Reference sink (local lab collector-as-sink or built image)
LAB_REFERENCE_SINK_IMAGE=local-reference-sink:lab
