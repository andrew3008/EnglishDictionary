    +currentTraceId(): Optional.empty
    +startSpan(...): SpanScope
  }

  class "NoopTraceOperations\n.NoOpSpanScope" as NoOpSpanScope <<inner singleton>> {
    {static} +INSTANCE
    +close(): void «no-op»
  }
}

