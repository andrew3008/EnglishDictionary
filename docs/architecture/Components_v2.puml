@startuml platform-tracing-08-runtime-sequence
skinparam backgroundColor #FEFEFE
skinparam sequenceMessageAlign center
skinparam defaultFontName "Segoe UI"

title Runtime: HTTP-запрос в Servlet-приложении с Java Agent

actor Client
participant "TraceResponseHeader\nServletFilter" as Filter
participant "Spring MVC\n+ Micrometer Obs" as MVC
participant "PlatformServerRequest\nObservationConvention" as Conv
participant "PlatformTracing\n(bean)" as PT
participant "DefaultPlatformTracing" as DPT
participant "OpenTelemetry\n(GlobalOpenTelemetry)" as OT
participant "Java Agent\n+ otel-extension" as Agent
participant "OTLP Exporter" as Export
database "Collector / Jaeger" as Backend

== JVM startup ==
Agent -> OT : SDK init (bootstrap CL)
Agent -> Agent : CompositeSampler\nSpanProcessor pipeline\nPlatformResourceProvider
note over Agent
  TracingMdcContextAutoConfiguration регистрирует
  TracingMdcContextWrapper в ContextStorage
  (до первого span, @AutoConfigureBefore Core)
end note

== Spring context ==
MVC -> Conv : onObservation start/end
Conv -> OT : platform.* attributes on span

== Incoming HTTP request ==
Client -> Filter : GET /api/...\n(traceparent?)
Filter -> PT : currentTraceId()
PT -> DPT : delegate
DPT -> OT : Span.current()
Filter --> Client : response + X-Request-Id

MVC -> OT : auto-instrumented SERVER span
Conv -> OT : enrich semconv + platform attrs

== Business code (@Traced) ==
MVC -> PT : startInternal("OrderService.create")
PT -> DPT : tracer.spanBuilder
DPT -> OT : makeCurrent / end

== Error path ==
MVC -> PT : recordException(e)
PT -> OT : span.recordException + platform.result=failure

== Export (async BSP) ==
OT -> Agent : onEnd processors\n(enrich/scrub/validate/watchdog)
Agent -> Export : batch spans
Export -> Backend : OTLP

== Dynamic sampling (ops) ==
note over Agent
  Actuator POST /actuator/tracing
  → SamplingControlClient (JMX)
  → PlatformTracingControl.setSamplingRatio
  → MutableRatioSampler (без restart JVM)
end note

@enduml


@startuml platform-tracing-09-config-dual-channel
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"

title Конфигурация: dual-channel mapping (Spring ↔ Agent)

map "TracingProperties\n(Spring @ConfigurationProperties)" as spring_cfg {
  platform.tracing.enabled => enabled
  platform.tracing.service.* => service.name/version/env
  platform.tracing.sampling.ratio => ratio
  platform.tracing.sampling.force-record-header => X-Trace-On
  platform.tracing.sampling.qa-header => X-QA-Trace
  platform.tracing.limits.* => span limits (logical)
  platform.tracing.queue.* => BSP tuning (logical)
  platform.tracing.scrubbing.* => scrubbing rules
  platform.tracing.response.* => response headers
  platform.tracing.service-names.* => remote service enrichment
  platform.tracing.mdc.context-wrapper-enabled => MDC sync
}

map "Agent configuration\n(ExtensionPropertyNames, PlatformTracingDefaultsProvider)" as agent_cfg {
  platform.tracing.sampling.ratio => SAMPLING_RATIO
  platform.tracing.sampling.force-record-header => SAMPLING_FORCE_RECORD_HEADER
  platform.tracing.sampling.drop-paths => SAMPLING_DROP_PATHS
  platform.tracing.enriching.* => EnrichingSpanProcessor
  platform.tracing.scrubbing.* => ScrubbingSpanProcessor
  platform.tracing.validation.enabled => ValidatingSpanProcessor
  platform.tracing.watchdog.* => SpanWatchdogProcessor
  otel.bsp.* => SDK queue/batch (addPropertiesSupplier)
  otel.span.*.limit => SDK span limits
}

map "Operational delivery" as delivery {
  application.yml / Spring Cloud Config => spring_cfg
  OTEL_* env / -D / Helm values => agent_cfg
  JMX => runtime ratio override
}

spring_cfg ..> agent_cfg : **semantic parity,\nnot automatic sync**

note as N_risk
  **Architectural debt**
  Изменение defaults в TracingProperties не меняет
  agent configuration / PlatformTracingDefaultsProvider / otel defaults автоматически.
  Рефакторинг: единый ConfigModel + два Adapter'а
  (SpringBinder, OtelConfigPropertiesBinder).
end note

@enduml


@startuml platform-tracing-10-refactoring-hotspots
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"

title Карта точек рефакторинга для архитекторов

together {
  rectangle "R1 — Configuration unification" as R1 #FFCDD2 {
    card "TracingProperties\n↔ agent configuration\n↔ otel.* defaults"
    card "Риск рассинхронизации\nпри изменении defaults"
    card "**Proposal:** shared config module\nor codegen from single YAML schema"
  }

  rectangle "R2 — SPI completeness" as R2 #F8BBD0 {
    card "SamplingDecisionContributor\n declared in api,\n not used in CompositeSampler"
    card "SpanEnricher — no wired\n ServiceLoader in extension"
    card "**Proposal:** unified ExtensionRegistry\nwith ordered contributors"
  }

  rectangle "R3 — Module boundaries" as R3 #E1BEE7 {
    card "autoconfigure knows\nServlet + Reactive + Actuator\n(compileOnly proliferation)"
    card "**Proposal:** split autoconfigure\n→ core-autoconfigure\n  servlet-autoconfigure\n  reactive-autoconfigure"
  }

  rectangle "R4 — PlatformTracing layering" as R4 #C5CAE9 {
    card "MeteredPlatformTracing\n@Primary decorator in Spring"
    card "Core stays pure OTel"
    card "**Proposal:** move metrics decorator\nto optional metrics-autoconfigure\n(or Micrometer Observation only)"
  }

  rectangle "R5 — Starter granularity" as R5 #B2DFDB {
    card "starter-servlet = 2 lines Gradle"
    card "Reactive starter mirrors servlet"
    card "**Proposal:** single starter + profile\nor BOM-only consumption pattern"
  }

