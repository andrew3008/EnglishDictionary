' =============================================================================
' spring-boot-platform-tracing — архитектурная документация (PlantUML)
' Версия артефактов: 0.1.0-SNAPSHOT | Java 21 | Spring Boot 3.5.5 | OTel 1.61.0
' Модули: api, core, otel-extension, spring-boot-autoconfigure, starter-servlet
' Назначение: детальный обзор для архитекторов перед рефакторингом
' =============================================================================

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam roundcorner 8
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultFontName "Segoe UI"
skinparam ArrowColor #444444
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F9A825

title Модульная карта зависимостей\nspace.br1440.platform.tracing (Gradle multi-project)

package "Платформа (внешние BOM)" as ext #ECEFF1 {
  component [platform-tracing-bom] as bom <<BOM>>
  component [Spring Boot 3.5.5] as sb
  component [OpenTelemetry BOM 1.61.0] as otelbom
  component [OTel Instrumentation BOM 2.27.0] as instbom
}

package "Приложение сервиса (Servlet)" as app #E8F5E9 {
  component [spring-boot-starter-platform-tracing-servlet\nplatform-tracing-spring-boot-starter-servlet] as starter <<Starter>>
  component [spring-boot-starter-web] as web
}

package "Spring Boot интеграция" as spring #E3F2FD {
  component [platform-tracing-spring-boot-autoconfigure] as autoconf <<AutoConfig>>
  component [micrometer-tracing-bridge-otel] as bridge <<optional dev>>
}

package "Доменная реализация" as domain #FFF3E0 {
  component [platform-tracing-core] as core <<Library>>
  component [platform-tracing-api] as api <<Library>>
}

package "OpenTelemetry Java Agent (bootstrap CL)" as agent #F3E5F5 {
  component [platform-tracing-otel-extension] as otel_ext <<Agent Extension>>
  component [OpenTelemetry Java Agent 2.27.x] as javaagent
}

package "Инфраструктура observability" as infra #FAFAFA {
  component [OTel Collector] as collector
  component [Jaeger / OTLP backend] as backend
  component [spring-boot-starter-platform-logging] as logging <<optional>>
  component [spring-boot-starter-platform-metrics] as metrics <<optional>>
}

' --- Gradle api / implementation edges ---
starter --> autoconf : api
starter --> web : api
starter --> bom : BOM import

autoconf --> api : api
autoconf --> core : api
autoconf --> sb : implementation\n(autoconfigure, aop, web*)
autoconf --> otelbom : api\n(opentelemetry-api)
autoconf --> bom

core --> api : api
core --> otelbom : api\n(opentelemetry-api)
core --> bom

api --> bom : api
api --> jakarta : jakarta.annotation-api

otel_ext --> api : implementation\n(SPI contracts, headers)
otel_ext --> javaagent : otel.javaagent.extensions\n+ SPI registration
otel_ext --> bom

javaagent --> collector : OTLP
collector --> backend

app ..> logging : traceId/spanId ← MDC reader\n(OpenTelemetryAppender writer)
app ..> bridge : opt-in dev/staging\n(suppress=false, no Agent)
autoconf ..> bridge : compileOnly\n(Wave 2c — not transitive)
autoconf ..> metrics : MeteredPlatformTracing\n(@Primary decorator)

note right of starter
  **Тонкий агрегатор**
  Содержит только build.gradle:
  • api → autoconfigure
  • api → spring-boot-starter-web
  Нет собственного Java-кода.
end note

note bottom of otel_ext
  **Отдельный classloader**
  Extension живёт в bootstrap/agent CL.
  Spring-приложение общается через JMX
  (SamplingControlClient ↔ PlatformTracingControl MBean).
end note

legend right
  |= Обозначение |= Смысл |
  | <<Starter>> | Точка подключения в POM/Gradle сервиса |
  | <<AutoConfig>> | Spring Boot 3 AutoConfiguration.imports |
  | <<Agent Extension>> | SPI AutoConfigurationCustomizerProvider |
  | * compileOnly | Servlet/WebFlux/Actuator — опционально |
endlegend

@enduml


