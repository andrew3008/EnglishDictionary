title Слоистая архитектура и границы ответственности

rectangle "L0 — Потребитель" as L0 #E8F5E9 {
  card "Микросервис\n(Spring MVC + Tomcat)" as svc
}

rectangle "L1 — Composition Root" as L1 #C8E6C9 {
  card "starter-servlet" as st
}

rectangle "L2 — Framework Adapter" as L2 #BBDEFB {
  together {
    card "TracingCoreAutoConfiguration" as core_cfg
    card "ServletTracingAutoConfiguration" as servlet_cfg
    card "TracingObservationAutoConfiguration" as obs_cfg
    card "TracingAopAutoConfiguration" as aop_cfg
    card "TracingMetricsAutoConfiguration" as metrics_cfg
    card "TracingMdcContextAutoConfiguration" as mdc_cfg
    card "TracingActuatorAutoConfiguration" as act_cfg
    card "ServiceNameProviderAutoConfiguration" as svc_cfg
    card "RequestContextSupplierAutoConfiguration" as ctx_cfg
    card "TracingRefreshScopeAutoConfiguration" as refresh_cfg
  }
}

rectangle "L3 — Application Port" as L3 #FFE0B2 {
  card "PlatformTracing\n(interface)" as pt
  card "@Traced / SpanScope\nSpanCategory / SpanResult" as ann
  card "SPI:\nSpanEnricher\nSensitiveDataRule\nSamplingDecisionContributor" as spi
  card "TracingRequestContext\nTracingMdcKeys\nPlatformHeaders" as cross
}

rectangle "L4 — Domain Adapter" as L4 #FFCC80 {
  card "DefaultPlatformTracing\n→ OpenTelemetry Tracer" as dpt
  card "NoOpPlatformTracing" as noop
  card "MeteredPlatformTracing\n(decorator)" as metered
}

rectangle "L5 — Telemetry SDK / Agent" as L5 #E1BEE7 {
  card "OpenTelemetry API\n(GlobalOpenTelemetry / bean)" as otapi
  card "Java Agent + otel-extension\nSampler / SpanProcessors / Resource" as agent
}

rectangle "L6 — Export Pipeline" as L6 #CFD8DC {
  card "BatchSpanProcessor\nOTLP Exporter" as bsp
  card "Collector + tail_sampling" as coll
}

svc --> st
st --> L2
L2 --> pt : inject bean
L2 --> ann : AOP / Observation conventions
pt <|.. dpt
pt <|.. noop
pt <|.. metered : @Primary\n(if MeterRegistry)
dpt --> otapi
agent --> otapi : инициализирует SDK\nдо старта Spring
agent --> bsp
bsp --> coll

note as N_boundary
  **Ключевая граница рефакторинга L3/L4**
  api — zero Spring, zero OTel SDK (только jakarta.annotation).
  core — OTel API, без Spring.
  autoconfigure — единственное место Spring-зависимостей.
end note

note as N_dup
  **Дублирование конфигурации (риск)**
  TracingProperties (Spring) и agent configuration
  (ExtensionPropertyNames, ExtensionDefaults, PlatformTracingDefaultsProvider)
  описывают одни доменные понятия (sampling, limits, scrubbing)
  через разные каналы доставки.
end note

