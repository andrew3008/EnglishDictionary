@startuml
left to right direction

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 95
skinparam shadowing false

package "platform-tracing-api" as API {
}

package "platform-tracing-core\n(скоуп этой задачи)" {

  package "Entry Layer" as ENTRY {
    component "Facade" as FACADE
    component "Propagation\n(context transfer)" as PROP
  }

  package "Manual Tracing Pipeline" as MANUAL {
    component "HTTP / RPC / Kafka / DB /\nGeneric Span Builders" as BUILDERS
  }

  package "Runtime" as PORT {
    component "Tracing Runtime SPI" as RUNTIME
    component "Runtime State" as STATE
    component "Trace Context View" as CTXVIEW
  }

  package "OTel Adapter" as ADAPTER {
    component "OTel Tracing Runtime" as OTELRUNTIME
    component "Span Scopes" as SCOPE
    component "Context Marker" as MARKER
  }

  package "Naming & Semconv Policy" as POLICY {
    component "Span Naming" as NAMING
    component "Attribute Policy\n(safe/unsafe, validation)" as SEMCONV
  }

  component "Exception Recording" as EXC
  component "Enrichment" as ENRICH

  package "Cross-cutting Policies" as CROSS {
    component "Sampling" as SAMPLING
    component "Validation" as VALIDATION
  }

}

package "OpenTelemetry SDK / API" as OTEL {
}

' -----------------------------------------------------------------------------
' Layout only: keep one readable central lane and push support concerns down.
' -----------------------------------------------------------------------------
API -[hidden]right-> FACADE
FACADE -[hidden]right-> BUILDERS
BUILDERS -[hidden]right-> RUNTIME
RUNTIME -[hidden]right-> OTELRUNTIME
OTELRUNTIME -[hidden]right-> OTEL

BUILDERS -[hidden]down-> POLICY
RUNTIME -[hidden]down-> EXC
OTELRUNTIME -[hidden]down-> ENRICH
POLICY -[hidden]right-> EXC
EXC -[hidden]right-> ENRICH
POLICY -[hidden]down-> CROSS

' -----------------------------------------------------------------------------
' Main runtime path: left to right, no support blocks in the middle.
' -----------------------------------------------------------------------------
API <.. FACADE
API <.. BUILDERS

FACADE -right-> BUILDERS : manual()
FACADE -down-> PROP
FACADE -right-> RUNTIME

BUILDERS -right-> RUNTIME : startSpan(spec)
RUNTIME -right-> CTXVIEW
RUNTIME -down-> STATE
RUNTIME <|.. OTELRUNTIME
OTELRUNTIME -right-> OTEL

' -----------------------------------------------------------------------------
' Support concerns: intentionally drawn below the main path.
' -----------------------------------------------------------------------------
BUILDERS -down-> NAMING
BUILDERS -down-> SEMCONV
BUILDERS -down-> EXC

OTELRUNTIME -down-> SCOPE
OTELRUNTIME -down-> MARKER
PROP -right-> OTEL
EXC -right-> OTEL

ENRICH -up-> MARKER
ENRICH -left-> SEMCONV
ENRICH -right-> OTEL

BUILDERS -down-> SAMPLING
VALIDATION -left-> SAMPLING

note bottom of PORT
  Runtime Port не зависит от OpenTelemetry.
  Это чистый порт trace-возможностей.
end note

note bottom of ADAPTER
  Полный доступ к OTel trace/context API
  сосредоточен в adapter boundary.
end note

note bottom of CROSS
  Sampling / Validation изолированы
  от трассировочного SDK.
end note

@enduml
