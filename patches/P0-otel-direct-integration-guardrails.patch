From: Platform Traces P0 OTel Direct Integration Guardrails
Date: Mon, 25 May 2026 00:00:00 +0000
Subject: [PATCH] P0: OTel Direct Integration Guardrails

Architecture hardening без runtime refactor:
- ADR + compatibility matrix
- Gradle verifyOtelBomAlignment
- ArchUnit Rules 1-4 + self-tests

Проверка: ./gradlew check verifyOtelBomAlignment

---
diff --git a/build.gradle b/build.gradle
--- a/build.gradle
+++ b/build.gradle
@@ -105,3 +105,46 @@
 tasks.register("publishAllToMavenLocal") {
     dependsOn subprojects.publishToMavenLocal
 }
+// Проверка согласованности OTel instrumentation BOM и alpha-версии extension API.
+tasks.register('verifyOtelBomAlignment') {
+    group = 'verification'
+    description = 'Verifies that OpenTelemetry instrumentation alpha version is aligned with instrumentation BOM version.'
+    notCompatibleWithConfigurationCache(
+            'Reads Gradle properties at execution time for version alignment check')
+
+    def instrumentationBomVersionProvider =
+            providers.gradleProperty('openTelemetryInstrumentationBomVersion')
+    def instrumentationAlphaVersionProvider =
+            providers.gradleProperty('openTelemetryInstrumentationAlphaVersion')
+
+    doLast {
+        def instrumentationBomVersion = instrumentationBomVersionProvider.orNull?.trim()
+        def instrumentationAlphaVersion = instrumentationAlphaVersionProvider.orNull?.trim()
+
+        if (!instrumentationBomVersion) {
+            throw new GradleException(
+                    'Missing required Gradle property: openTelemetryInstrumentationBomVersion')
+        }
+        if (!instrumentationAlphaVersion) {
+            throw new GradleException(
+                    'Missing required Gradle property: openTelemetryInstrumentationAlphaVersion')
+        }
+
+        def expectedAlphaVersion = "${instrumentationBomVersion}-alpha"
+        if (instrumentationAlphaVersion != expectedAlphaVersion) {
+            throw new GradleException(
+                    "OpenTelemetry version mismatch: " +
+                    "openTelemetryInstrumentationAlphaVersion=${instrumentationAlphaVersion}, " +
+                    "expected ${expectedAlphaVersion} based on " +
+                    "openTelemetryInstrumentationBomVersion=${instrumentationBomVersion}")
+        }
+    }
+}
+
+gradle.projectsEvaluated {
+    subprojects.each { sub ->
+        sub.tasks.matching { it.name == 'check' }.configureEach {
+            dependsOn rootProject.tasks.named('verifyOtelBomAlignment')
+        }
+    }
+}

