# M8b — overloaded Collector: nginx отвечает 429 (60%, +Retry-After) / 503 (40%) на OTLP.
# HARD GATE: RSS стабилен, без unbounded retries, drops учитываются по reason (REQ-BACKPRESSURE-001).
SCENARIO_ID=m8b
PERF_COMPOSE_PROFILES=degraded
PERF_BACKPRESSURE=1
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-javaagent-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://backpressure:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1
