# M8a — slow Collector: toxiproxy (latency toxic 200ms) перед Collector'ом.
# HARD GATE: app-потоки не блокируются на exporter path (JFR ThreadPark = 0), RSS стабилен.
# Раннер при PERF_TOXIPROXY=latency создаёт proxy otlp: listen 4318 -> collector:4318 + toxic.
SCENARIO_ID=m8a
PERF_COMPOSE_PROFILES=degraded
PERF_TOXIPROXY=latency
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-javaagent-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://toxiproxy:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1
