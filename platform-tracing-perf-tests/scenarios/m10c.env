# M10c — config storm: частые ВАЛИДНЫЕ runtime-апдейты под нагрузкой
# (PR-E; ADR-runtime-sampling-policy, инварианты C-2/C-4/C-7; micro-аналог —
# CompositeSamplerConcurrentUpdateBenchmark).
# Раннер (PERF_RELOAD_STORM=valid) всю steady-фазу чередует ratio 0.1 <-> 0.5
# через perf-admin каждые PERF_RELOAD_STORM_INTERVAL_SEC. Это намеренно жёстче
# операционной реальности (единицы апдейтов в минуту) — верхний стресс-режим.
# Evidence (non-gating): p99/queue стабильны на всём окне storm'а;
# SamplingConfigVersion монотонно растёт (reload-storm.csv).
SCENARIO_ID=m10c
PERF_RELOAD_STORM=valid
PERF_RELOAD_STORM_INTERVAL_SEC=2
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-javaagent-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://collector:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1
