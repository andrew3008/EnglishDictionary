# M6 — Collector down: endpoint указывает на закрытый порт (connection refused).
# HARD GATE: p99 <= M0+50ms, без OOM, exit 0, RSS стабилен (инварианты P1/P3).
SCENARIO_ID=m6
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-javaagent-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://127.0.0.1:9 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1
