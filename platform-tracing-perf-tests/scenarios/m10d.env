# M10d — invalid config storm: поток НЕВАЛИДНЫХ runtime-апдейтов под нагрузкой
# (PR-E; ADR-runtime-sampling-policy, инвариант C-5 last-known-good).
# Раннер (PERF_RELOAD_STORM=invalid) всю steady-фазу шлёт ratio=5.0 (вне [0,1])
# каждые PERF_RELOAD_STORM_INTERVAL_SEC: каждый вызов обязан отвергаться
# (HTTP 500 от perf-admin = IllegalArgumentException MBean'а).
# Evidence (non-gating): p99/queue стабильны; SamplingRatio остаётся 0.1 (LKG),
# SamplingConfigVersion НЕ растёт, InvalidConfigCount растёт (reload-storm.csv).
SCENARIO_ID=m10d
PERF_RELOAD_STORM=invalid
PERF_RELOAD_STORM_INTERVAL_SEC=2
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://collector:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1
