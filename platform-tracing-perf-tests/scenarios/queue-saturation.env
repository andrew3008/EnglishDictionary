# Queue saturation — инвариант P2: bounded queue (capacity 32) + медленный Collector
# (toxiproxy latency) + ratio 1.0 => постоянное переполнение.
# Ветка A (этот файл): платформенный DROP_OLDEST. Ветка B: queue-saturation-upstream.env.
# HARD GATE: ExportQueueSize <= capacity, heap стабилен, droppedOverflow растёт (учёт потерь).
SCENARIO_ID=queue-saturation
PERF_COMPOSE_PROFILES=degraded
PERF_TOXIPROXY=latency
PERF_SAMPLE_EXPORT_METRICS=true
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-javaagent-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://toxiproxy:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=1.0 -Dotel.bsp.max.queue.size=32 -Dplatform.tracing.queue.overflow-policy=DROP_OLDEST
