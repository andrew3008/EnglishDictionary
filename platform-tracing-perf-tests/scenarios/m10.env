# M10 — runtime config reload под нагрузкой (инвариант P5).
# Раннер (PERF_RELOAD_SEQUENCE) в середине steady-фазы выполняет через perf-admin:
#   ratio 0.1 -> 0.5 -> 0.1; scrubbing off -> on; export off -> on.
# HARD GATE: p99 и queue стабильны в окне reload (бюджет dynconf-no-stall).
SCENARIO_ID=m10
PERF_RELOAD_SEQUENCE=true
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-javaagent-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://collector:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1
