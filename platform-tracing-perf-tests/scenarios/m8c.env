# M8c — flaky Collector: toxiproxy с периодическим timeout-toxic (10с on / 10с off).
# HARD GATE: без OOM/осцилляций RSS на ретраях OTLP-клиента, exit 0.
SCENARIO_ID=m8c
PERF_COMPOSE_PROFILES=degraded
PERF_TOXIPROXY=flaky
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://toxiproxy:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1
