# M4 — agent + extension MINIMAL: sampler и каркас без scrubbing (стоимость каркаса).
SCENARIO_ID=m4
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://collector:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=0.1 -Dplatform.tracing.scrubbing.enabled=false
