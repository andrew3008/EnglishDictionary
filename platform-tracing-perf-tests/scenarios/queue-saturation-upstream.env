# Queue saturation, ветка B: stock BatchSpanProcessor (UPSTREAM, drop-new) — равноправное
# сравнение overflow-политик (открытый вопрос 5 ADR-performance-model).
SCENARIO_ID=queue-saturation-upstream
PERF_COMPOSE_PROFILES=degraded
PERF_TOXIPROXY=latency
PERF_SAMPLE_EXPORT_METRICS=true
PERF_SCENARIO_JVM_OPTS=-javaagent:/otel/opentelemetry-javaagent.jar -Dotel.javaagent.extensions=/otel/platform-tracing-otel-javaagent-extension-agent.jar -Dotel.exporter.otlp.endpoint=http://toxiproxy:4318 -Dotel.exporter.otlp.protocol=http/protobuf -Dplatform.tracing.sampling.ratio=1.0 -Dotel.bsp.max.queue.size=32 -Dplatform.tracing.queue.overflow-policy=UPSTREAM
